# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Found in: Supabase dashboard → Project Settings → API → service_role (secret)
# Keep this server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The public URL of your deployed app (used to generate QR code join links)
# For local development use: http://localhost:3000
# For production use your Vercel URL, e.g.: https://quiz-game.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
